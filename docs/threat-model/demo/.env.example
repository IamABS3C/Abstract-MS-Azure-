# Copy to ".env" (same folder) and fill in. .env is git-ignored — never commit it.
# The demo reads these at runtime; the key is never printed or logged.

# Write-scoped API key for the target tenant (NOT the read-only MCP OAuth token).
ABSTRACT_API_KEY=

# API base. Default is https://api.abstractsecurity.app — override for a different tenant/region.
ABSTRACT_API_BASE=https://api.abstractsecurity.app

# Tenant / vendor account id, if the API requires it as a header (X-AS-Vendor-Account-ID).
# Leave blank if the key already scopes the tenant.
ABSTRACT_ACCOUNT_ID=
